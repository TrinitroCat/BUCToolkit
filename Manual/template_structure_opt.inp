# input template

# global configs
START: 1          # 0: from scratch; 1: load checkpoint from LOAD_CHK_FILE_PATH
DEVICE: 'cuda:0'
VERBOSE: 1
REDIRECT: true    # whether output training logs to OUTPUT_PATH or directlt print on screen.
SAVE_PREDICTIONS: false  # only for predictions. Whether output predictions to a npz file.
BATCH_SIZE: 1

# I/O configs
LOAD_CHK_FILE_PATH: /path/to/your/file/best_checkpoint.pt
OUTPUT_PATH: /path/to/your/file/
OUTPUT_POSTFIX: OPT
PREDICTIONS_SAVE_FILE: /path/to/your/file/Predictions.npz  # path of saving predictions
DUMP_FREQUENCY: 10

# relaxation
RELAXATION:
  ALGO: 'CG'  # CG, BFGS, FIRE
  ITER_SCHEME: 'PR+'  # only for ALGO=CG, 'PR+', 'FR', 'PR', 'WYL'
  E_THRES: 1.e-4  # convergence threshold of difference of Energy
  F_THRES: 0.1  # convergence threshold of max Force
  MAXITER: 300
  STEPLENGTH: 0.5
  USE_BB: true
  LINESEARCH: 'Wolfe'  # 'Backtrack' with Armijo's cond., 'Golden' for exact line search by golden section algo., 'Wolfe' for advance & retreat algo. with weak Wolfe cond.
  LINESEARCH_MAXITER: 20  # max iterations of linear search.
  LINESEARCH_THRES: 0.02  # only for LINESEARCH = 'Golden', threshold of exact line search.
  LINESEARCH_FACTOR: 0.5  # A factor in linesearch. Shrinkage factor for "Backtrack", scaling factor in interval search for "Golden"

# transition state search
# NOTICE: if both section `RELAXATION` and `TRANSITION_STATE` exist, the `TRANSITION_STATE` will be overwritten.
TRANSITION_STATE:
  ALGO: DIMER  # DIMER
  X_DIFF_ATTR: x_dimer  # str, the attribute name of the initial guess of dimer direction
  E_THRES: 1.e3  # convergence threshold of difference of Energy
  TORQ_THRES: 1.e-1  # convergence threshold of torque for dimer rotation
  F_THRES: 0.1  # convergence threshold of max Force
  MAXITER_TRANS: 100  # max iteration steps for dimer translation
  MAXITER_ROT: 5  # max iteration steps for dimer rotation within each translation step
  MAX_STEPLENGTH: 0.5  # max steplength cut-off for translation
  DX: 5.e-2  # finite difference steplength for Hessian-vector production

# model configs
MODEL_NAME: SOME_MODEL
MODEL_CONFIG: {}
  # Model hyperparameters ...
